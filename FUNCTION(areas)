def square():
    s=int(input("enter side:"))
    print("Area:",s*s)
def circle(r):
    print("Area:",r*r*3.14)
def rectangle(a,b):
    print("Area:",a*b)
while(True):
    print("1.Square")
    print("2.Circle")
    print("3.Rectangle")
    print("4.Exit")
    ch=int(input("enter ur choice:"))
    if ch==1:
        square()
    elif ch==2:
        circle(10)
    elif ch==3:
        rectangle(5,10)
    else:
        break
